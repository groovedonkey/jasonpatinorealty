# Database — Render provides this automatically for PostgreSQL
# For local dev, leave blank to use SQLite (./contacts.db)
DATABASE_URL=

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Google Sheets integration
# 1. Create a Google Cloud service account with Sheets API enabled
# 2. Share your spreadsheet with the service account email
# 3. Paste the full JSON key as a single line below
GOOGLE_SPREADSHEET_ID=
GOOGLE_CREDENTIALS_JSON=

# Email notifications (Gmail example — use an App Password, not your real password)
# To create a Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=
